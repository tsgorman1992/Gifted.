# gifted. — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env with real values to version control.
# See MIGRATION.md for full setup instructions.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# On Replit this is auto-provisioned. Elsewhere: Railway, Neon, Supabase, etc.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Session ──────────────────────────────────────────────────────────────────
# Long random string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: If not set, the app falls back to a weak default — always set this.
SESSION_SECRET=replace-with-a-long-random-string

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Docs: https://developers.google.com/identity/protocols/oauth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# The full redirect URL registered in Google Cloud Console for your environment.
# Must exactly match an entry in Authorized Redirect URIs.
# Example: https://yourdomain.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# ─── Stripe ───────────────────────────────────────────────────────────────────
# From Stripe Dashboard → Developers → API Keys
# Use sk_test_... for testing, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# From Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Event to handle: checkout.session.completed
# Webhook URL: https://yourdomain.com/api/gifted/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret

# ─── Twilio ───────────────────────────────────────────────────────────────────
# From Twilio Console → Account Info
# Used for: OTP verification and scheduled gift SMS delivery
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Your Twilio outbound phone number in E.164 format.
# Must be approved for toll-free SMS sending before use in production.
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Operator phone number — receives internal notifications when a gift is paid.
OPERATOR_PHONE=+1xxxxxxxxxx

# ─── Object Storage (Google Cloud Storage) ────────────────────────────────────
# On Replit, this bucket is auto-provisioned.
# Outside Replit: create a GCS bucket and a service account with Storage Object Admin role.
# Set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON key,
# or use Workload Identity in GCP-hosted environments.
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-gcs-bucket-name

# Path prefix inside the bucket where private objects (e.g. videos) are stored.
PRIVATE_OBJECT_DIR=private/

# Comma-separated path prefixes for publicly readable objects (e.g. photos).
PUBLIC_OBJECT_SEARCH_PATHS=public/

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL used when generating gift links sent via Twilio SMS.
# Must match your actual deployed domain.
APP_ORIGIN=https://yourdomain.com

# Server port. Most hosting platforms (Railway, Render, Fly.io) set this automatically.
# You do not usually need to set this manually.
PORT=8080
